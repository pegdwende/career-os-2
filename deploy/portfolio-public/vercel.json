{
  "cleanUrls": true,
  "functions": {
    "api/*.js": {
      "maxDuration": 30,
      "includeFiles": "{api/{private-data,private-prompts,private-templates,assets},server/admin-api}/**"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
